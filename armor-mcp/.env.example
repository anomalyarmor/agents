# AnomalyArmor MCP Server Environment Variables
#
# Stdio mode (default): Set ARMOR_API_KEY, leave MCP_TRANSPORT unset or "stdio"
# HTTP mode: Set MCP_TRANSPORT=http, CLERK_DOMAIN, and optionally MCP_BASE_URL

# === Common ===
# Backend API URL (defaults to https://api.anomalyarmor.ai)
# ARMOR_API_URL=https://api.anomalyarmor.ai

# === Stdio mode (CI/automation) ===
# ARMOR_API_KEY=aa_live_...

# === HTTP mode (hosted, Clerk OAuth) ===
# MCP_TRANSPORT=http
# CLERK_DOMAIN=clerk.your-domain.com
# MCP_BASE_URL=https://mcp.anomalyarmor.ai
# PORT=3001
